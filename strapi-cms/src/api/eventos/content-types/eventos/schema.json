{
  "kind": "collectionType",
  "collectionName": "evento",
  "info": {
    "singularName": "eventos",
    "pluralName": "evento",
    "displayName": "Eventos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Titulo": {
      "type": "string"
    },
    "Imagen": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Fecha": {
      "type": "date"
    },
    "TipoEvento": {
      "type": "enumeration",
      "enum": [
        "Conferencia",
        "Webinar",
        "Meetup",
        "Workshop"
      ]
    }
  }
}
